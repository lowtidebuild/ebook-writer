{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ebook-writer.local/schemas/outline.schema.json",
  "title": "Ebook Writer Structured Outline",
  "type": "object",
  "required": ["book_title", "target_audience", "chapters"],
  "properties": {
    "book_title": { "type": "string", "minLength": 1 },
    "target_audience": { "type": "string", "minLength": 1 },
    "language": { "type": "string", "minLength": 2 },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/chapter" }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "chapter": {
      "type": "object",
      "required": [
        "chapter_id",
        "slug",
        "title",
        "summary",
        "key_content",
        "estimated_words",
        "dependencies"
      ],
      "properties": {
        "chapter_id": { "type": "integer", "minimum": 1 },
        "slug": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "key_content": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "estimated_words": { "type": "integer", "minimum": 1 },
        "dependencies": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 }
        },
        "part": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    }
  }
}
